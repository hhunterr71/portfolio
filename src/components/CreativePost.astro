---
import { render } from 'astro:content';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'creative'>;
}

const { post } = Astro.props;
const { title, date, tags, media } = post.data;
const { Content } = await render(post);

const formattedDate = date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<article class="border border-ink/10 rounded-lg overflow-hidden">
  {media[0] && media[0].type === 'image' && (
    <Image src={media[0].src} alt={media[0].alt ?? title} width={700} class="w-full h-56 object-cover" />
  )}
  {media[0] && media[0].type === 'video-embed' && (
    <div class="aspect-video">
      <iframe src={media[0].src} title={title} class="w-full h-full" allowfullscreen></iframe>
    </div>
  )}

  <div class="p-5">
    <h3 class="font-heading font-bold text-lg mb-1">{title}</h3>
    <p class="text-muted text-xs mb-3">{formattedDate}</p>

    {tags && tags.length > 0 && (
      <ul class="flex flex-wrap gap-2 mb-3">
        {tags.map((tag) => (
          <li class="text-xs px-2 py-1 rounded-full bg-accent/10 text-accent font-heading">{tag}</li>
        ))}
      </ul>
    )}

    <div class="text-sm leading-relaxed">
      <Content />
    </div>
  </div>
</article>
