---
interface Props {
  href: string;
  label?: string;
  class?: string;
  variant?: 'light' | 'deep';
}

const { href, label = 'Scroll', class: className = '', variant = 'light' } = Astro.props;
const labelColor = variant === 'deep' ? 'text-on-deep/70' : 'text-muted';
---

<a href={href} class={`scroll-cue group flex flex-col items-center gap-1 ${className}`}>
  <span class={`text-[11px] font-heading font-semibold uppercase tracking-wide ${labelColor} group-hover:text-accent-warm transition-colors`}>
    {label}
  </span>
  <svg class="scroll-cue-arrow w-5 h-5 text-accent-warm" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25 12 15.75 4.5 8.25" />
  </svg>
</a>

<style>
  .scroll-cue-arrow {
    animation: scroll-cue-bounce 1.8s ease-in-out infinite;
  }
  @keyframes scroll-cue-bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(6px);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-cue-arrow {
      animation: none;
    }
  }
</style>
