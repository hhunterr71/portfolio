---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Spotlight from '../components/Spotlight.astro';
import DimensionLine from '../components/DimensionLine.astro';
import ScrollCue from '../components/ScrollCue.astro';
import { withBase } from '../lib/url';
import headshot from '../assets/hub/hunter-headshot.jpg';
import bikeHeadshot from '../assets/hub/hunter-bike-headshot.jpg';
import pmGraphic from '../assets/projects/predictive-maintenance/pm-graphic-1.png';
import vanPhoto from '../assets/projects/camper-van-build/van-1.jpg';
import surfBagPhoto from '../assets/projects/surf-fin-bag/surf-bag-5.jpg';

const spotlightItems = [
  {
    eyebrow: 'Featured Project',
    title: 'Predictive Maintenance Program',
    description: 'An automated HVAC predictive maintenance program — 87% prediction accuracy, 15% reduction in unexpected maintenance costs.',
    href: withBase('/projects/predictive-maintenance-program/'),
    image: pmGraphic,
  },
  {
    eyebrow: 'Featured Project',
    title: 'Crystal Parking Reservation Bot',
    description: 'A deployed Flask + Selenium app that watches a ski resort’s parking calendar and auto-reserves a spot the moment one opens.',
    href: withBase('/projects/crystal-parking-scraper/'),
    code: 'if "fc-unavailable" not in \n    calendar_day.get_attribute("class"):\n    calendar_day.click()\n    break',
  },
  {
    eyebrow: 'Resume Highlight',
    title: 'Trusted by major teams',
    description: 'Consults on data science engagements for client partners including Google, Walmart, Exxon, the Pentagon, Amazon, and Goldman Sachs.',
    href: withBase('/resume/'),
    icon: 'M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 0 0 .75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 0 0-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38a23.978 23.978 0 0 1-7.577 1.22c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 0 1-.673-.38m0 0A2.18 2.18 0 0 1 3 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 0 1 3.413-.387m7.5 0V5.25A2.25 2.25 0 0 0 13.5 3h-3a2.25 2.25 0 0 0-2.25 2.25v.894m7.5 0a48.667 48.667 0 0 0-7.5 0',
  },
  {
    eyebrow: 'Skill Highlight',
    title: 'From Data to Dashboards',
    description: 'Proficient in Python, SQL, Power BI, and Tableau — turning raw operational data into dashboards that drive real decisions.',
    href: withBase('/resume/#skills'),
    icon: 'M3 13.125c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z',
  },
  {
    eyebrow: 'Personal Project',
    title: 'Camper Van Build',
    description: 'Designed and built a multi-purpose adventure van from scratch, within a strict budget — gear garage, power, bed, and kitchen included.',
    href: withBase('/projects/camper-van-build/'),
    image: vanPhoto,
  },
  {
    eyebrow: 'Project Highlight',
    title: 'Surf Fin Bag',
    description: 'Hand-sewn from waterproof X-Pac fabric after finding nothing on the market that fit two fins, wax, and spare parts the way I needed.',
    href: withBase('/projects/surf-fin-bag/'),
    image: surfBagPhoto,
  },
  {
    eyebrow: 'Featured Project',
    title: 'Portfolio Site Rebuild',
    description: 'This very site — rebuilt with Astro and Tailwind, going from a design conversation to a deployed site in a single sitting.',
    href: withBase('/projects/portfolio-site-rebuild/'),
    code: 'const projects = defineCollection({\n  loader: glob({ pattern: "**/*.md",\n    base: "./src/content/projects" }),\n  schema: ({ image }) => z.object({ ... }),\n});',
  },
  {
    eyebrow: 'Creative',
    title: 'Postcards from Paradise',
    description: 'A professional ski film I helped film and have my own segment in — what really is paradise, anyway?',
    href: withBase('/creative/'),
    externalImage: 'https://img.youtube.com/vi/1s4Kv5K3kLs/hqdefault.jpg',
  },
  {
    eyebrow: 'Creative',
    title: 'Garage Beers (Coming Soon)',
    description: 'A bike film about The Summit at Snoqualmie, made by four guys, two cameras, and a real "water bottle and a dream" kind of vibe. Filming this summer.',
    href: withBase('/creative/'),
    image: bikeHeadshot,
  },
];

const links = [
  {
    href: withBase('/resume/'),
    label: 'Resume',
    description: 'Data analyst, mechanical engineer, and the professional path that got me here.',
    icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2Z',
  },
  {
    href: withBase('/projects/'),
    label: 'Projects',
    description: 'Software and hands-on engineering work, personal and professional.',
    icon: 'm6.75 7.5-3 4.5 3 4.5m10.5-9 3 4.5-3 4.5m-6-12-3 18',
  },
  {
    href: withBase('/creative/'),
    label: 'Creative',
    description: 'Mountain biking and skiing photo and video content.',
    icon: 'M6.827 6.175A2.31 2.31 0 0 1 8.94 4.5h6.122c.891 0 1.71.59 1.964 1.515l.319 1.16a1.5 1.5 0 0 0 1.448 1.103h.75A2.25 2.25 0 0 1 21.75 10.5v6A2.25 2.25 0 0 1 19.5 18.75h-15A2.25 2.25 0 0 1 2.25 16.5v-6A2.25 2.25 0 0 1 4.5 8.25h.75a1.5 1.5 0 0 0 1.448-1.103l.129-.972ZM12 15.75a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z',
  },
];
---

<BaseLayout title="Hunter Hamilton">
  <section class="relative overflow-hidden">
    <div class="water-light" aria-hidden="true"></div>
    <main class="relative flex flex-col items-center px-6 pt-16 pb-10 text-center">
      <div class="headshot-swap assemble-in relative w-44 h-44 sm:w-56 sm:h-56 mb-6" style="--assemble-delay:0ms">
        <Image
          src={headshot}
          alt="Hunter Hamilton"
          width={600}
          class="headshot-default absolute inset-0 w-full h-full rounded-full object-cover shadow-lg ring-4 ring-white transition-opacity duration-300"
        />
        <Image
          src={bikeHeadshot}
          alt="Hunter Hamilton mountain biking"
          width={600}
          class="headshot-bike absolute inset-0 w-full h-full rounded-full object-cover shadow-lg ring-4 ring-white opacity-0 transition-opacity duration-300"
        />
      </div>
      <h1 class="assemble-in font-heading font-bold text-3xl mb-2" style="--assemble-delay:120ms">Hunter Hamilton</h1>
      <p class="assemble-in text-muted mb-8" style="--assemble-delay:200ms">Data Analyst · Mechanical Engineer · Outdoor Content Creator</p>

      <div class="grid sm:grid-cols-3 gap-4 w-full max-w-3xl">
        {links.map((link, i) => (
          <a
            href={link.href}
            class="assemble-in group rounded-xl bg-accent/5 p-6 text-left ring-1 ring-accent/15 transition-all hover:-translate-y-1 hover:bg-accent/10 hover:shadow-lg hover:ring-accent/40"
            style={`--assemble-delay:${280 + i * 100}ms`}
          >
            <svg class="w-7 h-7 mb-3 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={link.icon} />
            </svg>
            <h2 class="font-heading font-bold mb-2">{link.label}</h2>
            <p class="text-muted text-sm">{link.description}</p>
          </a>
        ))}
      </div>

      <ScrollCue href="#highlights" label="Highlights" class="mt-10" />
    </main>
  </section>

  <DimensionLine />

  <section id="highlights" class="scroll-mt-6 bg-accent-deep text-on-deep">
    <div class="assemble-in max-w-3xl mx-auto px-6 py-16" style="--assemble-delay:0ms">
      <Spotlight items={spotlightItems} />
    </div>
  </section>
</BaseLayout>

<style>
  @media (hover: hover) {
    .headshot-swap:hover .headshot-default {
      opacity: 0;
    }
    .headshot-swap:hover .headshot-bike {
      opacity: 1;
    }
  }
</style>
